||    = readInput "day09" >>= parseSegs .> go
    = readFile "day09.txt" >>= parseSegs .> go
      where
        go si
            = output [part1, part2]
              where
                corners = cmap si |> m_keys
                rects   = [V2 a b | a : bs <- tails corners; b <- bs]                
                part1   = findMaxArea (const True) rects |> showint
                part2   = findMaxArea (inside si)  rects |> showint
